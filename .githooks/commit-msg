#!/usr/bin/env bash
# Fallback hooks when lefthook is not installed.
# Prefer: task setup  (installs lefthook)
# Or:     pwsh ./scripts/install-git-hooks.ps1
#
# Same Conventional Commits rules as scripts/validate-commit-subject.sh.
# Merge / cherry-pick / revert commits are skipped (MERGE_HEAD, etc.).

set -euo pipefail

msg_file=$1
if [[ ! -f "$msg_file" ]]; then
  echo "commit-msg: missing message file: $msg_file" >&2
  exit 1
fi

# Merge / cherry-pick / revert commits are not subject to Conventional Commits.
# Git sets these refs while the commit is being created.
git_dir=$(git rev-parse --git-dir)
if [[ -f "$git_dir/MERGE_HEAD" ]] ||
   [[ -f "$git_dir/CHERRY_PICK_HEAD" ]] ||
   [[ -f "$git_dir/REVERT_HEAD" ]]; then
  exit 0
fi

# First non-comment, non-empty line is the subject
subject=""
while IFS= read -r line || [[ -n "$line" ]]; do
  line=${line//$'\r'/}
  # Git commit template comments
  [[ "$line" =~ ^# ]] && continue
  [[ -z "${line// }" ]] && continue
  subject=$line
  break
done <"$msg_file"

root=$(git rev-parse --show-toplevel)
validator="$root/scripts/validate-commit-subject.sh"

if [[ ! -f "$validator" ]]; then
  echo "commit-msg: validator not found: $validator" >&2
  exit 1
fi

bash "$validator" "$subject"

if ! grep -q "^Signed-off-by:" "$msg_file"; then
  echo "ERROR: Missing DCO sign-off. Use 'git commit -s'" >&2
  exit 1
fi
